// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Exploitant {
  id          String   @id @default(cuid())
  name        String
  frDecNumber String   @unique
  siret       String?
  numCamo     String?
  adresse     String?
  codePostal  String?
  ville       String?
  pays        String   @default("France")
  telephone   String?
  email       String?
  website     String?
  contactName String?
  logoUrl     String?
  billetPrefix String?  @default("BIL")
  users       User[]
  ballons     Ballon[]
  pilotes     Pilote[]
  vols        Vol[]
  billets     Billet[]
  passagers   Passager[]
  paiements    Paiement[]
  weatherCache WeatherCache[]
  tags         Tag[]
  equipiers      Equipier[]
  vehicules      Vehicule[]
  sitesDecollage SiteDecollage[]
  meteoLatitude  Float?
  meteoLongitude Float?
  meteoSeuilVent Int?     @default(28)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("exploitant")
}

model Ballon {
  id                     String     @id @default(cuid())
  exploitantId           String
  exploitant             Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  nom                    String
  immatriculation        String
  volumeM3               Int
  nbPassagerMax          Int
  peseeAVide             Int
  configGaz              String
  manexAnnexRef          String
  mtom                   Int?
  mlm                    Int?
  performanceChart       Json
  camoOrganisme          String?
  camoExpiryDate         DateTime?
  certificatNavigabilite String?
  vols                   Vol[]
  actif                  Boolean    @default(true)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  @@unique([exploitantId, immatriculation])
  @@index([exploitantId])
  @@map("ballon")
}

model Pilote {
  id                       String     @id @default(cuid())
  exploitantId             String
  exploitant               Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  userId                   String?    @unique
  prenom                   String
  nom                      String
  email                    String?
  telephone                String?
  poidsEncrypted           String?
  // BFCL licence
  licenceBfcl              String
  dateExpirationLicence    DateTime
  heuresDeVol              Int?

  // BFCL.200 — classe de ballon (A = air chaud, B = gaz, C = dirigeable air chaud, D = dirigeable gaz)
  classeA                  Boolean    @default(true)
  classeB                  Boolean    @default(false)
  classeC                  Boolean    @default(false)
  classeD                  Boolean    @default(false)

  // BFCL.200 — groupe dans la classe A (taille enveloppe)
  // 1: <= 3400 m3, 2: 3401-6000 m3, 3: 6001-10500 m3, 4: > 10500 m3
  groupeA1                 Boolean    @default(false)
  groupeA2                 Boolean    @default(false)
  groupeA3                 Boolean    @default(false)
  groupeA4                 Boolean    @default(false)

  // BFCL.215 — vol commercial passagers
  qualificationCommerciale Boolean    @default(false)
  // BFCL.210 — vol de nuit
  qualificationNuit        Boolean    @default(false)
  // BFCL.300 — instructeur (BFI)
  qualificationInstructeur Boolean    @default(false)
  // Vol captif (tethered)
  qualificationCaptif      Boolean    @default(false)
  vols                     Vol[]
  actif                    Boolean    @default(true)
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt

  @@index([exploitantId])
  @@map("pilote")
}

enum UserRole {
  ADMIN_CALPAX
  GERANT
  PILOTE
  EQUIPIER
}

model User {
  id            String  @id @default(cuid())
  email         String  @unique
  name          String
  emailVerified Boolean @default(false)
  image         String?

  exploitantId String
  exploitant   Exploitant @relation(fields: [exploitantId], references: [id])

  role UserRole @default(GERANT)

  // Account lockout: when set and in the future, login attempts are rejected
  lockedUntil  DateTime?

  // Admin ban (Better Auth admin plugin): banned users cannot sign in.
  // `banExpires` null = permanent, date in future = temporary ban.
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([exploitantId])
  @@map("user")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("session")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SIGN_IN
  SIGN_IN_FAILED
  SIGN_OUT
  PASSWORD_RESET
  PASSWORD_CHANGED
  ACCOUNT_LOCKED
}

enum TypePlannif {
  MATIN
  SOIR
  TOUTE_LA_JOURNEE
  AU_PLUS_VITE
  AUTRE
  A_DEFINIR
}

enum StatutBillet {
  EN_ATTENTE
  PLANIFIE
  VOLE
  ANNULE
  REMBOURSE
  EXPIRE
}

enum StatutPaiement {
  EN_ATTENTE
  PARTIEL
  SOLDE
  REMBOURSE
}

enum ModePaiement {
  ESPECES
  CHEQUE
  CB
  VIREMENT
  CHEQUE_VACANCES
  AVOIR
}

enum StatutVol {
  PLANIFIE
  CONFIRME
  TERMINE
  ARCHIVE
  ANNULE
}

enum Creneau {
  MATIN
  SOIR
}

// Tracks failed sign-in attempts per email to power account lockout.
// Rows older than the lockout window are pruned opportunistically on each miss.
model FailedLoginAttempt {
  id        BigInt   @id @default(autoincrement())
  email     String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@map("failed_login_attempt")
}

model AuditLog {
  id             BigInt      @id @default(autoincrement())
  exploitantId   String?
  userId         String?
  impersonatedBy String?
  entityType     String
  entityId       String
  action         AuditAction
  field          String?
  beforeValue    Json?
  afterValue     Json?
  createdAt      DateTime    @default(now())

  @@index([exploitantId, entityType, entityId])
  @@index([impersonatedBy])
  @@index([createdAt])
  @@map("audit_log")
}

model BilletSequence {
  exploitantId String
  year         Int
  lastSeq      Int    @default(0)

  @@id([exploitantId, year])
  @@map("billet_sequence")
}

model Billet {
  id              String         @id @default(cuid())
  exploitantId    String
  exploitant      Exploitant     @relation(fields: [exploitantId], references: [id], onDelete: Cascade)

  reference       String
  checksum        String

  typePlannif     TypePlannif    @default(A_DEFINIR)
  dateVolDeb      DateTime?
  dateVolFin      DateTime?
  dateValidite    DateTime?

  payeurCiv       String?
  payeurPrenom    String
  payeurNom       String
  payeurEmail     String?
  payeurTelephone String?
  payeurAdresse   String?
  payeurCp        String?
  payeurVille     String?

  statut          StatutBillet   @default(EN_ATTENTE)
  statutPaiement  StatutPaiement @default(EN_ATTENTE)
  montantTtc      Decimal  @db.Decimal(10, 2)
  enAttente       Boolean        @default(false)

  categorie       String?
  provenance      String?
  lieuDecollage   String?
  survol          String?
  commentaire     String?

  // Bon cadeau
  estBonCadeau         Boolean   @default(false)
  dateCadeau           DateTime?
  destinataireNom      String?
  destinataireEmail    String?
  organisateurNom      String?
  organisateurEmail    String?
  organisateurTelephone String?

  dateRappel      DateTime?

  passagers       Passager[]
  paiements       Paiement[]
  tags            BilletTag[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([exploitantId, reference])
  @@index([exploitantId])
  @@index([exploitantId, statut])
  @@index([exploitantId, dateRappel])
  @@map("billet")
}

model Passager {
  id              String     @id @default(cuid())
  exploitantId    String
  exploitant      Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  billetId        String
  billet          Billet     @relation(fields: [billetId], references: [id], onDelete: Cascade)

  prenom          String
  nom             String
  email           String?
  telephone       String?
  emailEncrypted     String?
  telephoneEncrypted String?
  age             Int?
  poidsEncrypted  String?
  pmr             Boolean    @default(false)

  volId           String?
  vol             Vol?       @relation(fields: [volId], references: [id])

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([exploitantId])
  @@index([billetId])
  @@index([volId])
  @@map("passager")
}

model Paiement {
  id               String       @id @default(cuid())
  exploitantId     String
  exploitant       Exploitant   @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  billetId         String
  billet           Billet       @relation(fields: [billetId], references: [id], onDelete: Cascade)

  modePaiement     ModePaiement
  montantTtc       Decimal      @db.Decimal(10, 2)
  datePaiement     DateTime
  dateEncaissement DateTime?
  commentaire      String?

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([exploitantId])
  @@index([billetId])
  @@map("paiement")
}

model Tag {
  id           String     @id @default(cuid())
  exploitantId String
  exploitant   Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  nom          String
  couleur      String?

  billets      BilletTag[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([exploitantId, nom])
  @@index([exploitantId])
  @@map("tag")
}

model BilletTag {
  billetId String
  billet   Billet @relation(fields: [billetId], references: [id], onDelete: Cascade)
  tagId    String
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([billetId, tagId])
  @@map("billet_tag")
}

model Vol {
  id              String     @id @default(cuid())
  exploitantId    String
  exploitant      Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)

  date            DateTime   @db.Date
  creneau         Creneau
  statut          StatutVol  @default(PLANIFIE)

  ballonId        String
  ballon          Ballon     @relation(fields: [ballonId], references: [id])
  piloteId        String
  pilote          Pilote     @relation(fields: [piloteId], references: [id])

  equipierId      String?
  equipierEntity  Equipier?  @relation(fields: [equipierId], references: [id])
  equipierAutre   String?

  vehiculeId      String?
  vehiculeEntity  Vehicule?  @relation(fields: [vehiculeId], references: [id])
  vehiculeAutre   String?

  siteDecollageId    String?
  siteDecollageEntity SiteDecollage? @relation(fields: [siteDecollageId], references: [id])
  lieuDecollageAutre String?

  configGaz       String?
  qteGaz          Int?

  decoLieu        String?
  decoHeure       DateTime?
  atterLieu       String?
  atterHeure      DateTime?
  distance        Int?
  gasConso        Int?
  anomalies       String?
  noteDansCarnet  Boolean    @default(false)
  meteoAlert      Boolean    @default(false)
  cancelReason    String?

  pvePdfUrl       String?
  pveArchivedAt   DateTime?

  passagers       Passager[]

  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([exploitantId, date, creneau, ballonId])
  @@index([exploitantId])
  @@index([exploitantId, date])
  @@map("vol")
}

model Equipier {
  id             String     @id @default(cuid())
  exploitantId   String
  exploitant     Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  prenom         String
  nom            String
  telephone      String?
  actif          Boolean    @default(true)
  vols           Vol[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([exploitantId])
  @@map("equipier")
}

model Vehicule {
  id             String     @id @default(cuid())
  exploitantId   String
  exploitant     Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  nom            String
  immatriculation String?
  actif          Boolean    @default(true)
  vols           Vol[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([exploitantId])
  @@map("vehicule")
}

model SiteDecollage {
  id             String     @id @default(cuid())
  exploitantId   String
  exploitant     Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  nom            String
  adresse        String?
  latitude       Float?
  longitude      Float?
  notes          String?
  actif          Boolean    @default(true)
  vols           Vol[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([exploitantId])
  @@map("site_decollage")
}

model WeatherCache {
  id             String     @id @default(cuid())
  exploitantId   String
  exploitant     Exploitant @relation(fields: [exploitantId], references: [id], onDelete: Cascade)
  latitude       Float
  longitude      Float
  date           DateTime   @db.Date
  data           Json
  fetchedAt      DateTime   @default(now())

  @@unique([exploitantId, date])
  @@index([exploitantId])
  @@map("weather_cache")
}
